# Twilio Agent Connect - Environment Variables
# Copy this file to .env and update with your values

# Required
TWILIO_TAC_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TAC_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TAC_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TAC_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TAC_PHONE_NUMBER=+1xxxxxxxxxx
TWILIO_TAC_CONVERSATION_SERVICE_SID=conv_configuration_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional - Voice Channel (ngrok domain without https://)
TWILIO_TAC_VOICE_PUBLIC_DOMAIN=your-domain.ngrok.app

# Optional - OpenAI Example
TWILIO_TAC_OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
