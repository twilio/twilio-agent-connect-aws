# Lambda Deployment
# Deploys Lambda Function URL that proxies Twilio webhooks to AgentCore runtime
# Command: cd cdk && cdk deploy
# Prerequisites: AgentCore agent deployed, Docker running

# AgentCore Runtime ARN (from agent deployment output)
# Get this after running: cd ../agent/agentcore && agentcore deploy
AGENTCORE_RUNTIME_ARN=arn:aws:bedrock-agentcore:us-east-1:123456789012:runtime/tacagent-xxxxx

# Twilio Conversation Configuration ID
TWILIO_CONVERSATION_CONFIGURATION_ID=WRxxxx

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
