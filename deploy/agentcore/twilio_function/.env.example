# Twilio Function Deployment
# Deploys Twilio Function that proxies webhooks to AgentCore runtime
# Prerequisites: AgentCore agent deployed, IAM user created

# AgentCore Runtime ARN (from agent deployment output)
# Get this after running: cd ../agent/agentcore && agentcore deploy
AGENTCORE_RUNTIME_ARN=arn:aws:bedrock-agentcore:us-east-1:123456789012:runtime/tacagent-xxxxx

# Twilio Configuration
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_CONVERSATION_CONFIGURATION_ID=WRxxxx

# AWS IAM User Credentials (from IAM deployment)
# Get these after running: cd cdk && cdk deploy
# IMPORTANT: Twilio Functions run outside AWS, so they need access keys (not IAM roles)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
