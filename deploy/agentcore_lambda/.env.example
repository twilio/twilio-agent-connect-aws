# ============================================================================
# AWS Twilio Agent Connect - Environment Variables
# ============================================================================
# Copy to .env and fill in your values.
# Deploy in order: infra → agentcore → lambda
# ============================================================================

# ----------------------------------------------------------------------------
# AWS CLI Configuration - Required for all deployments
# ----------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_PROFILE=your-aws-profile-name

# ----------------------------------------------------------------------------
# Infrastructure [INFRA] - Deploy first with infra/deploy.sh
# ----------------------------------------------------------------------------
# S3 bucket for deployment packages (AgentCore and Lambda)
S3_BUCKET=tac-deployment-bucket

# ----------------------------------------------------------------------------
# Twilio Configuration - Required for agentcore and lambda deployments
# ----------------------------------------------------------------------------
TWILIO_CONVERSATION_CONFIGURATION_ID=conv_configuration_xxxxx

# ----------------------------------------------------------------------------
# AgentCore Configuration [AGENTCORE] - Deploy second with agentcore/deploy.sh
# ----------------------------------------------------------------------------
# Twilio credentials for TAC integration
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_API_KEY=SKxxxxx
TWILIO_API_SECRET=your_api_secret
TWILIO_PHONE_NUMBER=+1xxxxx
TWILIO_LOG_LEVEL=DEBUG

# ----------------------------------------------------------------------------
# Lambda Configuration [LAMBDA] - Deploy last with lambda/deploy.sh
# ----------------------------------------------------------------------------
# AgentCore Runtime ID (get from agentcore deployment output)
AGENTCORE_RUNTIME_ID=tacagent-xxxxx
