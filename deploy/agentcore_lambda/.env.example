# ============================================================================
# AWS Twilio Agent Connect - Environment Variables
# ============================================================================
# This file contains all environment variables needed for both Lambda and
# AgentCore services. Copy to .env and fill in your values.
#
# Services: [BOTH] [AGENTCORE] [LAMBDA]
# ============================================================================

# ----------------------------------------------------------------------------
# Shared Configuration [BOTH]
# ----------------------------------------------------------------------------
# AWS CLI configuration (for deployment scripts only)
AWS_REGION=us-east-1
AWS_PROFILE=your-aws-profile-name

# Twilio Conversation Configuration ID (used in TwiML and AgentCore)
TWILIO_CONVERSATION_CONFIGURATION_ID=conv_configuration_xxxxx

# ----------------------------------------------------------------------------
# AgentCore Configuration [AGENTCORE]
# ----------------------------------------------------------------------------
# TAC credentials for making Twilio API calls
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_API_KEY=SKxxxxx
TWILIO_API_SECRET=your_api_secret
TWILIO_PHONE_NUMBER=+1xxxxx
TWILIO_LOG_LEVEL=DEBUG

# ----------------------------------------------------------------------------
# Lambda Configuration [LAMBDA]
# ----------------------------------------------------------------------------
# The AgentCore Runtime ID (created when deploying agentcore/)
AGENTCORE_RUNTIME_ID=tacagent-xxxxx

# S3 bucket for Lambda deployment packages
S3_BUCKET=your-s3-bucket-for-lambda-packages

# CloudFormation stack name for Lambda deployment
STACK_NAME=tac-proxy
