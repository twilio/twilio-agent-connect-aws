# ============================================================================
# AgentCore + Twilio Function - Environment Variables
# ============================================================================
# Copy to .env and fill in your values.
# Deploy in order: agentcore → infra (IAM) → twilio_function
# ============================================================================

# ----------------------------------------------------------------------------
# AWS CLI Configuration - Required for agentcore deployment
# ----------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_PROFILE=your-aws-profile-name

# ----------------------------------------------------------------------------
# Twilio Configuration - Required for agentcore and twilio_function
# ----------------------------------------------------------------------------
TWILIO_CONVERSATION_CONFIGURATION_ID=conv_configuration_xxxxx

# ----------------------------------------------------------------------------
# AgentCore Configuration [AGENTCORE] - Deploy first with agentcore/deploy.sh
# ----------------------------------------------------------------------------
# Twilio credentials for TAC integration
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_API_KEY=SKxxxxx
TWILIO_API_SECRET=your_api_secret
TWILIO_PHONE_NUMBER=+1xxxxx
TWILIO_LOG_LEVEL=DEBUG

# ----------------------------------------------------------------------------
# AgentCore Runtime ARN [AGENTCORE] - Required for Twilio Function
# ----------------------------------------------------------------------------
# Full AgentCore Runtime ARN (get from agentcore deployment output)
# Format: arn:aws:bedrock-agentcore:REGION:ACCOUNT_ID:runtime/RUNTIME_ID
# Example: arn:aws:bedrock-agentcore:us-east-1:123456789012:runtime/tacagent-xxxxx
AGENTCORE_RUNTIME_ARN=arn:aws:bedrock-agentcore:us-east-1:YOUR_ACCOUNT_ID:runtime/tacagent-xxxxx

# ----------------------------------------------------------------------------
# Twilio Function Configuration [TWILIO_FUNCTION]
# ----------------------------------------------------------------------------
# AWS IAM User credentials for Twilio Functions to access AgentCore
# IMPORTANT: Must use access keys (not IAM roles) since Twilio Functions
# run outside AWS.
#
# To create IAM credentials:
#   cd infra
#   aws cloudformation create-stack --stack-name tac-agentcore-twilio-function-iam \
#     --template-body file://cloudformation.yaml \
#     --capabilities CAPABILITY_NAMED_IAM --profile YOUR_AWS_PROFILE
#
# Get outputs:
#   aws cloudformation describe-stacks --stack-name tac-agentcore-twilio-function-iam \
#     --query 'Stacks[0].Outputs' --profile YOUR_AWS_PROFILE
#
# This creates IAM user with permissions: bedrock-agentcore:*

# AWS IAM Access Keys (from infra/cloudformation.yaml outputs)
AWS_ACCESS_KEY_ID=AKIA_YOUR_ACCESS_KEY_HERE
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here
