# Twilio Function — Bedrock Agent over SMS

# ACCOUNT_SID + AUTH_TOKEN authenticate the twilio-run deploy.
# API_KEY + API_SECRET are used by the handler for the Actions API (Basic auth).
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=your_api_secret
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Bedrock Agent
BEDROCK_AGENT_ID=XXXXXXXXXX
BEDROCK_AGENT_ALIAS_ID=TSTALIASID

# AWS IAM User Credentials
# Twilio Functions run outside AWS, so they need access keys (not IAM roles).
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional
# TWILIO_REGION=
# SERVICE_NAME=tac-bedrock
# DEBUG=true   # log the Bedrock agent reasoning trace to the live logs
