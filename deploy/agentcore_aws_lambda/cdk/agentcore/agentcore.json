{
  "$schema": "https://schema.agentcore.aws.dev/v1/agentcore.json",
  "name": "tac",
  "version": 1,
  "managedBy": "CDK",
  "tags": {
    "agentcore:created-by": "agentcore-cli",
    "agentcore:project-name": "tac"
  },
  "runtimes": [
    {
      "name": "tac_agent",
      "build": "CodeZip",
      "entrypoint": "main.py",
      "codeLocation": "../agent/",
      "runtimeVersion": "PYTHON_3_14",
      "networkMode": "PUBLIC",
      "protocol": "HTTP",
      "requestHeaderAllowlist": [
        "X-Twilio-Signature"
      ],
      "filesystemConfigurations": [
        {
          "sessionStorage": {
            "mountPath": "/mnt/workspace"
          }
        }
      ]
    }
  ],
  "memories": [],
  "credentials": [],
  "evaluators": [],
  "onlineEvalConfigs": [],
  "agentCoreGateways": [],
  "policyEngines": [],
  "configBundles": [],
  "abTests": [],
  "httpGateways": [],
  "datasets": []
}